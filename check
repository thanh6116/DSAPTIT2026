//XÂU CON ĐỐI XỨNG DÀI NHẤT 
int lcs(string &s)
{
    int res = 1;
    int len = s.sz;
    int l, r;
    for(int i = 1; i < len; ++i)
    {
        l = i - 1;
        r = i;
        while(l >= 0 and r < len and s[l] == s[r])
        {
            --l;
            ++r;
        }
        ++l;
        --r;
        if(s[l] == s[r] and r - l + 1 > res) res = r - l + 1;
        l = i - 1;
        r = i + 1;
        while(l >= 0 and r < len and s[l] == s[r])
        {
            --l;
            ++r;
        }
        ++l;
        --r;
        if(s[l] == s[r] and r - l + 1 > res) res = r - l + 1;
    }
    return res;
}

