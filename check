#include<bits/stdc++.h>
using namespace std;

int main(){
    int n, k;
    cin >> n >> k;
    vector<long long> a(n+1);
    for(int i = 1; i<=n; i++) cin >> a[i];

    vector<long long> prefix(n+1, 0);
    for(int i = 1; i<=n; i++) prefix[i] = prefix[i-1] + a[i];

    vector<long long> dp(n+1, 0);
    dp[0] = 0;
    for(int i = 1; i<=n; i++){
        long long best;
        if(i < k){
            best = prefix[i]; // chua du K phan tu lien tiep, chon het
        }
        else{
            best = 0;
        }
        int lo = max(1, i-k+1);
        for(int j = lo; j<=i; j++){
            long long val = (prefix[i]-prefix[j-1]) - a[j] + dp[j-1];
            best = max(best, val);
        }
        dp[i] = best;
    }
    cout << dp[n] << endl;
}
