int a[200], b[200];
void backtracking(int pos1, int pos2)
{
    if (pos2 == k)
    {
        ans++;
        return;
    }
    for (int i = pos1 + 1; i < n; i++)
    {
        if (a[i] > a[pos1])
        {
            b[pos2 + 1] = a[i];
            backtracking(i, pos2 + 1);
        }
    }
}
