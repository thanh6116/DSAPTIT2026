inline int levelOrder(binTree root)
{
    int MAX = -1;
    queue<pair<binTree, int>> q;
    pair<binTree, int> top;
    q.push({root, 0});
    while(q.sz)
    {
        top = q.front();
        q.pop();
        if(top.fi -> left == NULL)
        {
            if(MAX == -1)
                MAX = top.se;
            else if(top.se != MAX)
                return 0;
        }
        else
            q.push({top.fi -> left, top.se + 1});
        if(top.fi -> right == NULL)
        {
            if(MAX == -1)
                MAX = top.se;
            else if(top.se != MAX)
                return 0;
        }
        else
            q.push({top.fi -> right, top.se + 1});
    }
    return 1;
}
